# Copy this file to `deploy/ai.e3d.maps-runner.env` on the production machine.
# That local file is ignored by git and is sourced by `deploy/ai.e3d.maps-runner.plist`.

# OpenAI
LLM_BASE_URL=https://api.openai.com
LLM_MODEL=gpt-4o-mini
QWEN_API_KEY=

# E3D API
E3D_BASE_URL=https://e3d.ai
E3D_API_KEY=

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false

# Adapter
MAPS_ADAPTER_PATH=
MAPS_ADAPTER_NAME=base-v0
MAPS_ENABLE_ADAPTER_LOADING=false

# Cadence
MAPS_RUNNER_INTERVAL_SECONDS=300
MAPS_SCORING_INTERVAL_SECONDS=1800
MAPS_UTILITY_INTERVAL_SECONDS=3600
MAPS_EXPORT_INTERVAL_SECONDS=86400
MAPS_FLOW_GRAPH_INTERVAL_SECONDS=300
MAPS_TRAFFIC_STATE_INTERVAL_SECONDS=300
MAPS_CROSS_CHAIN_ACTIVITY_INTERVAL_SECONDS=300
MAPS_NEWS_INTERVAL_SECONDS=300
MAPS_SCHEDULER_TICK_SECONDS=60

# Runtime
QWEN_TIMEOUT=60
MAPS_ENV=production
