# ─── Shared Qwen LLM settings (also used by e3d-agent-trading-floor) ──────────
# LLM_BASE_URL and LLM_MODEL are canonical. Maps also accepts QWEN_BASE_URL and
# MAPS_DEFAULT_MODEL as fallbacks for backward compatibility.
LLM_BASE_URL=http://127.0.0.1:5050
LLM_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit
QWEN_API_KEY=
QWEN_COMPLETIONS_PATH=/v1/chat/completions

# ─── Maps adapter ─────────────────────────────────────────────────────────────
# Sent as X-Adapter-Path header per request — same pattern as SCOUT_ADAPTER_PATH
# and HARVEST_ADAPTER_PATH in the trading floor.
# Set to empty string to run the base model without an adapter (bootstrap period).
MAPS_ADAPTER_PATH=./adapters_maps_v1
MAPS_ADAPTER_NAME=base-v0
MAPS_ENABLE_ADAPTER_LOADING=false

# ─── E3D API ──────────────────────────────────────────────────────────────────
E3D_BASE_URL=https://e3d.ai
E3D_API_PREFIX=/api
E3D_API_KEY=

# ─── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false

# ─── Runner / scheduler cadence ───────────────────────────────────────────────
# All intervals are in seconds. Defaults match the spec-recommended cadences.
MAPS_RUNNER_INTERVAL_SECONDS=300
MAPS_SCORING_INTERVAL_SECONDS=1800
MAPS_UTILITY_INTERVAL_SECONDS=3600
MAPS_EXPORT_INTERVAL_SECONDS=86400
MAPS_SCHEDULER_TICK_SECONDS=60
MAPS_QUESTION_QUEUE_PATH=
MAPS_RUNNER_USE_SAMPLE_CONTEXT=false
MAPS_RUNNER_USE_SAMPLE_RESPONSES=false

# ─── On-chain payment gating (x402 / E3DToken on Base) ───────────────────────
# Mainnet RPC for agent tier lookups via E3DNFTManager
ETH_RPC_URL=
ETH_NFT_MANAGER_ADDRESS=0xeED4620ff525101Ffcf7327378232CA9EF778D47

# Base L2 RPC for verifying wE3D credit purchases
BASE_RPC_URL=https://mainnet.base.org

# Wrapped E3D address on Base (from: npm run check in E3DToken/wormhole-e3d-base/)
WRAPPED_E3D_BASE_ADDRESS=

# Treasury address on Base that collects per-call wE3D payments
MAPS_TREASURY_ADDRESS=

# ─── Misc ─────────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
MAPS_ENV=development
MAPS_SCHEMA_VERSION=1.0
